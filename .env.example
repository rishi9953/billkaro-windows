# Razorpay Configuration
# Copy this file to .env and replace with your actual Razorpay keys
# Test keys: https://dashboard.razorpay.com/app/keys
# Production keys: https://dashboard.razorpay.com/app/keys (switch to live mode)

RAZORPAY_KEY_TEST=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_PRODUCTION=rzp_live_xxxxxxxxxxxxx
RAZORPAY_ENVIRONMENT=test

# Twilio (WhatsApp) - get from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
